    { "name": "Game board shows header bar", "path": "/#game/2", "expectSelector": "header" },
    { "name": "Game board shows nation strip", "path": "/#game/2", "expectSelector": ".nation-strip" },
    { "name": "Game board shows hint bar", "path": "/#game/2", "expectSelector": "#hint-bar" },
    { "name": "Game board shows bundle buttons", "path": "/#game/2", "expectText": "44 tokens" },
    { "name": "Game board shows Mute control", "path": "/#game/2", "expectText": "Mute" },
